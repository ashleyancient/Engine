<Window x:Class="Engine.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Engine.ViewModels"
        Title="Engine"
        Width="900" Height="600"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        FontFamily="{StaticResource UiFont}"
        FontSize="{StaticResource FontSizeBase}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.DataContext>
        <vm:AuthViewModel/>
    </Window.DataContext>

    <Border Background="{DynamicResource PrimaryBrush}"
            CornerRadius="18"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.45*"/>
                <ColumnDefinition Width="0.55*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: hero panel -->
            <Border Grid.Column="0" CornerRadius="18,0,0,18"
                    MouseLeftButtonDown="OnDragHeader">
                <Border.Background>
                    <StaticResource ResourceKey="HeroGradientBrush"/>
                </Border.Background>
                <Grid>
                    <!-- Decorative floating circles -->
                    <Canvas IsHitTestVisible="False">
                        <Ellipse Width="180" Height="180" Canvas.Left="-40" Canvas.Top="60" Opacity="0.18">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="C1"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="C1"
                                                             Storyboard.TargetProperty="Y"
                                                             From="0" To="40" Duration="0:0:6"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Ellipse Width="240" Height="240" Canvas.Left="180" Canvas.Top="320" Opacity="0.14">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="White" Offset="0"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="C2"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="C2"
                                                             Storyboard.TargetProperty="Y"
                                                             From="0" To="-30" Duration="0:0:8"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Canvas>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <Border Width="84" Height="84" CornerRadius="20"
                                Background="#33FFFFFF" HorizontalAlignment="Center">
                            <TextBlock Text="E"
                                       FontFamily="{StaticResource UiFontSemibold}"
                                       FontSize="46"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ENGINE"
                                   FontFamily="{StaticResource UiFontSemibold}"
                                   FontSize="32"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,4"/>
                        <TextBlock Text="Connect beyond limits"
                                   FontSize="14"
                                   Foreground="#CCFFFFFF"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,40"/>
                        <TextBlock Text="Современный мессенджер"
                                   FontFamily="{StaticResource UiFontSemibold}"
                                   FontSize="16"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="и социальная сеть нового поколения"
                                   FontSize="12"
                                   Foreground="#BBFFFFFF"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT: form -->
            <Grid Grid.Column="1" Background="{DynamicResource PrimaryBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Custom titlebar (close/minimize) -->
                <Grid Grid.Row="0" Height="36" Background="Transparent" MouseLeftButtonDown="OnDragHeader">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,8,0">
                        <Button Style="{StaticResource WindowControlButton}"
                                Click="OnMinimize"
                                ToolTip="Свернуть">
                            <Path Data="M 0 0 L 12 0" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"/>
                        </Button>
                        <Button Style="{StaticResource WindowControlButton}"
                                Click="OnClose"
                                ToolTip="Закрыть">
                            <Path Data="M 0 0 L 12 12 M 12 0 L 0 12"
                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                  StrokeThickness="1.5"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="40,0,40,30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab toggle -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="14"
                            Padding="6"
                            Margin="0,16,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Войти"
                                    Command="{Binding SwitchToLoginCommand}"
                                    FontFamily="{StaticResource UiFontSemibold}"
                                    Padding="14,10">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoginMode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="1" Content="Регистрация"
                                    Command="{Binding SwitchToRegisterCommand}"
                                    FontFamily="{StaticResource UiFontSemibold}"
                                    Padding="14,10">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRegisterMode}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <!-- LOGIN -->
                        <ScrollViewer Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="С возвращением"
                                           Style="{StaticResource TitleText}"
                                           FontSize="22"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Введите свои данные, чтобы продолжить"
                                           Style="{StaticResource SecondaryText}"
                                           Margin="0,0,0,18"/>

                                <TextBlock Text="Email или username" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,12">
                                    <TextBox Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="40,10,12,10"/>
                                    <Path Data="M 2 4 L 14 4 L 14 12 L 2 12 Z M 2 4 L 8 9 L 14 4"
                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                          StrokeThickness="1.4"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          IsHitTestVisible="False"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="14,0,0,0"/>
                                </Grid>

                                <TextBlock Text="Пароль" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,4">
                                    <PasswordBox x:Name="LoginPasswordBox"
                                                 PasswordChanged="OnLoginPasswordChanged"
                                                 Padding="40,10,90,10"
                                                 Visibility="{Binding ShowLoginPassword, Converter={StaticResource InvBoolToVis2}}"/>
                                    <TextBox Text="{Binding LoginPassword, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="40,10,90,10"
                                             Visibility="{Binding ShowLoginPassword, Converter={StaticResource BoolToVis}}"/>
                                    <Path Data="M 4 7 L 4 12 L 12 12 L 12 7 M 5 7 L 5 5 A 3 3 0 0 1 11 5 L 11 7"
                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                          StrokeThickness="1.4"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          IsHitTestVisible="False"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="14,0,0,0"/>
                                    <Button Style="{StaticResource LinkButton}"
                                            Content="{Binding ShowLoginPasswordToggleText}"
                                            Command="{Binding TogglePasswordVisibilityCommand}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,14,0"/>
                                </Grid>

                                <Grid Margin="0,12,0,18">
                                    <CheckBox Content="Запомнить меня" IsChecked="{Binding RememberMe}"/>
                                    <Button Style="{StaticResource LinkButton}"
                                            Content="Забыли пароль?"
                                            HorizontalAlignment="Right"/>
                                </Grid>

                                <Button Content="ВОЙТИ"
                                        Style="{StaticResource AccentButton}"
                                        Command="{Binding LoginCommand}"
                                        Height="48"
                                        FontSize="14"/>

                                <Border CornerRadius="10"
                                        Padding="12,8"
                                        Margin="0,16,0,0"
                                        Background="{DynamicResource CardBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Демо-аккаунты:" Style="{StaticResource SecondaryText}"/>
                                        <TextBlock Text="admin@nexus.com / password123"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="user@nexus.com / qwerty"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding StatusMessage}"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource OnlineBrush}"/>
                                            <Setter Property="FontFamily" Value="{StaticResource UiFontSemibold}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- REGISTER -->
                        <ScrollViewer Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Создайте аккаунт"
                                           Style="{StaticResource TitleText}"
                                           FontSize="22"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Заполните форму, чтобы присоединиться к Engine"
                                           Style="{StaticResource SecondaryText}"
                                           Margin="0,0,0,18"/>

                                <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Cursor="Hand"
                                            Command="{Binding ChangeAvatarCommand}"
                                            ToolTip="Сменить цвет аватара">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Ellipse Width="80" Height="80">
                                                        <Ellipse.Fill>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="{Binding RegAvatarStart, Converter={StaticResource HexToBrush}}" Offset="0"/>
                                                                <GradientStop Color="{Binding RegAvatarEnd, Converter={StaticResource HexToBrush}}" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock Text="фото" Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontFamily="{StaticResource UiFontSemibold}"
                                                               FontSize="13"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Имя" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding RegFirstName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Фамилия" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding RegLastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Username (только латиница)" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding RegUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding UsernameError}"
                                           Foreground="{DynamicResource DangerBrush}"
                                           FontSize="11"
                                           Margin="4,0,0,8"/>

                                <TextBlock Text="Email" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding RegEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding EmailError}"
                                           Foreground="{DynamicResource DangerBrush}"
                                           FontSize="11"
                                           Margin="4,0,0,8"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Пароль" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                                        <PasswordBox x:Name="RegPasswordBox" PasswordChanged="OnRegPasswordChanged" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding PasswordError}"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   FontSize="11"
                                                   Margin="4,0,0,8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Повторите пароль" Style="{StaticResource SecondaryText}" Margin="0,0,0,4"/>
                                        <PasswordBox x:Name="RegConfirmBox" PasswordChanged="OnRegConfirmChanged" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding ConfirmError}"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   FontSize="11"
                                                   Margin="4,0,0,8"/>
                                    </StackPanel>
                                </Grid>

                                <CheckBox Content="Я принимаю условия использования"
                                          IsChecked="{Binding RegAcceptTerms}"
                                          Margin="0,8,0,16"/>

                                <Button Content="СОЗДАТЬ АККАУНТ"
                                        Style="{StaticResource AccentButton}"
                                        Command="{Binding RegisterCommand}"
                                        Height="48"
                                        FontSize="14"/>

                                <TextBlock Text="{Binding StatusMessage}"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource OnlineBrush}"/>
                                            <Setter Property="FontFamily" Value="{StaticResource UiFontSemibold}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>