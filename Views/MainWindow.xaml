<Window x:Class="Engine.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Engine.ViewModels"
        xmlns:p="clr-namespace:Engine.Views.Pages"
        xmlns:c="clr-namespace:Engine.Views.Controls"
        xmlns:s="clr-namespace:Engine.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Engine"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{StaticResource UiFont}"
        FontSize="{StaticResource FontSizeBase}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="OnGlobalKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Border Background="{DynamicResource PrimaryBrush}"
            CornerRadius="14"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnDragHeader">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="14,0,0,0">
                    <Border Width="20" Height="20" CornerRadius="6"
                            Background="{DynamicResource AccentGradientBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="E" Foreground="White"
                                   FontFamily="{StaticResource UiFontSemibold}"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="ENGINE"
                               FontFamily="{StaticResource UiFontSemibold}"
                               FontSize="13"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                    <TextBlock Text="·"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0"/>
                    <TextBlock Text="{Binding SectionTitle}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,2,8,0">
                    <Button Style="{StaticResource WindowControlButton}"
                            Click="OnMinimize" ToolTip="Свернуть">
                        <Path Data="M 0 0 L 12 0" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"/>
                    </Button>
                    <Button Style="{StaticResource WindowControlButton}"
                            Click="OnMaximize" ToolTip="Развернуть">
                        <Path Data="M 0 0 L 10 0 L 10 10 L 0 10 Z"
                              Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.4"
                              Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                    <Button Style="{StaticResource WindowControlButton}"
                            Click="OnClose" ToolTip="Закрыть">
                        <Path Data="M 0 0 L 12 12 M 12 0 L 0 12"
                              Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- MAIN AREA -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT NAV -->
                <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- USER AVATAR -->
                        <Grid Grid.Row="0" Margin="0,16,0,8" HorizontalAlignment="Center"
                              ToolTip="{Binding CurrentUser.FullName}">
                            <c:AvatarControl Size="44"
                                             Initials="{Binding CurrentUser.Initials}"
                                             ColorStart="{Binding CurrentUser.AvatarColorStart}"
                                             ColorEnd="{Binding CurrentUser.AvatarColorEnd}"
                                             ShowOnline="{Binding CurrentUser.IsOnline}"/>
                        </Grid>

                        <!-- NAV ITEMS -->
                        <StackPanel Grid.Row="1" Margin="0,16,0,0">
                            <Button Tag="{x:Static s:AppSection.Chats}"
                                    Click="OnNavigate"
                                    Style="{StaticResource IconButton}"
                                    Width="48" Height="48"
                                    Margin="12,4"
                                    ToolTip="Чаты">
                                <Grid>
                                    <Path Data="M 0 0 L 16 0 L 16 11 L 9 11 L 6 14 L 6 11 L 0 11 Z"
                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                          StrokeThickness="1.6"
                                          Stretch="Uniform" Width="20" Height="20"
                                          Fill="Transparent">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChatsActive}" Value="True">
                                                        <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Grid>
                            </Button>

                            <Button Tag="{x:Static s:AppSection.Contacts}"
                                    Click="OnNavigate"
                                    Style="{StaticResource IconButton}"
                                    Width="48" Height="48"
                                    Margin="12,4"
                                    ToolTip="Контакты">
                                <Path Data="M 5 5 A 3 3 0 1 0 5.01 5 M 0 16 A 5 5 0 0 1 10 16 M 11 6 A 2.5 2.5 0 1 0 11.01 6 M 16 16 A 4 4 0 0 0 10 13"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.5"
                                      Stretch="Uniform" Width="20" Height="20"
                                      Fill="Transparent">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsContactsActive}" Value="True">
                                                    <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>

                            <Button Tag="{x:Static s:AppSection.Stories}"
                                    Click="OnNavigate"
                                    Style="{StaticResource IconButton}"
                                    Width="48" Height="48"
                                    Margin="12,4"
                                    ToolTip="Истории">
                                <Ellipse Width="20" Height="20" StrokeThickness="2">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Stroke" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStoriesActive}" Value="True">
                                                    <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </Button>

                            <Button Tag="{x:Static s:AppSection.Channels}"
                                    Click="OnNavigate"
                                    Style="{StaticResource IconButton}"
                                    Width="48" Height="48"
                                    Margin="12,4"
                                    ToolTip="Каналы">
                                <Path Data="M 0 4 L 8 4 L 12 0 L 12 12 L 8 8 L 0 8 Z"
                                      Stretch="Uniform" Width="20" Height="20"
                                      Fill="Transparent" StrokeThickness="1.5">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Stroke" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChannelsActive}" Value="True">
                                                    <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>

                            <Button Tag="{x:Static s:AppSection.Favorites}"
                                    Click="OnNavigate"
                                    Style="{StaticResource IconButton}"
                                    Width="48" Height="48"
                                    Margin="12,4"
                                    ToolTip="Избранное">
                                <Path Data="M 6 0 L 8 4 L 12 4 L 9 7 L 10 11 L 6 9 L 2 11 L 3 7 L 0 4 L 4 4 Z"
                                      Stretch="Uniform" Width="20" Height="20"
                                      Fill="Transparent" StrokeThickness="1.5">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Stroke" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFavoritesActive}" Value="True">
                                                    <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>

                            <Grid Margin="12,4">
                                <Button Tag="{x:Static s:AppSection.Notifications}"
                                        Click="OnNavigate"
                                        Style="{StaticResource IconButton}"
                                        Width="48" Height="48"
                                        ToolTip="Уведомления">
                                    <Path Data="M 8 0 A 6 6 0 0 1 14 6 L 14 10 L 16 13 L 0 13 L 2 10 L 2 6 A 6 6 0 0 1 8 0 Z M 6 14 A 2 2 0 0 0 10 14"
                                          Stretch="Uniform" Width="20" Height="20"
                                          Fill="Transparent" StrokeThickness="1.5">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Stroke" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsNotificationsActive}" Value="True">
                                                        <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Button>
                                <Border Background="{DynamicResource DangerBrush}"
                                        CornerRadius="9"
                                        Width="18" Height="18"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,2,2,0"
                                        Visibility="{Binding UnreadNotificationsCount, Converter={StaticResource CountToVis}}">
                                    <TextBlock Text="{Binding UnreadNotificationsCount}"
                                               Foreground="White"
                                               FontSize="10"
                                               FontFamily="{StaticResource UiFontSemibold}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- BOTTOM NAV -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,16">
                            <Button Tag="{x:Static s:AppSection.Settings}"
                                    Click="OnNavigate"
                                    Style="{StaticResource IconButton}"
                                    Width="48" Height="48"
                                    Margin="12,4"
                                    ToolTip="Настройки">
                                <Path Data="M 8 5 A 3 3 0 1 0 8.01 5 M 8 0 L 9 2 L 11 1 L 12 3 L 14 4 L 14 6 L 16 8 L 14 10 L 14 12 L 12 13 L 11 15 L 9 14 L 8 16 L 7 14 L 5 15 L 4 13 L 2 12 L 2 10 L 0 8 L 2 6 L 2 4 L 4 3 L 5 1 L 7 2 Z"
                                      Stretch="Uniform" Width="20" Height="20"
                                      Fill="Transparent" StrokeThickness="1.4">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Stroke" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                                    <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>
                            <Button Click="OnLogout"
                                    Style="{StaticResource IconButton}"
                                    Width="48" Height="48"
                                    Margin="12,4"
                                    ToolTip="Выйти">
                                <Path Data="M 6 0 L 0 0 L 0 12 L 6 12 M 4 6 L 12 6 M 9 3 L 12 6 L 9 9"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.5"
                                      Stretch="Uniform" Width="20" Height="20"
                                      Fill="Transparent"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}"/>

                <!-- CONTENT AREA -->
                <Grid Grid.Column="2">
                    <Grid x:Name="PageRoot">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="PageT" X="0"/>
                        </Grid.RenderTransform>

                        <p:ChatsPage Visibility="{Binding IsChatsActive, Converter={StaticResource BoolToVis}}"/>
                        <p:ContactsPage Visibility="{Binding IsContactsActive, Converter={StaticResource BoolToVis}}"/>
                        <p:StoriesPage Visibility="{Binding IsStoriesActive, Converter={StaticResource BoolToVis}}"/>
                        <p:ChannelsPage Visibility="{Binding IsChannelsActive, Converter={StaticResource BoolToVis}}"/>
                        <p:FavoritesPage Visibility="{Binding IsFavoritesActive, Converter={StaticResource BoolToVis}}"/>
                        <p:NotificationsPage Visibility="{Binding IsNotificationsActive, Converter={StaticResource BoolToVis}}"/>
                        <p:SettingsPage Visibility="{Binding IsSettingsActive, Converter={StaticResource BoolToVis}}"/>
                    </Grid>

                    <!-- STORY OVERLAY -->
                    <Grid Background="#CC000000"
                          Visibility="{Binding IsStoryOverlayVisible, Converter={StaticResource BoolToVis}}">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="420" Height="640">
                            <Border CornerRadius="20" ClipToBounds="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{Binding ActiveStory.GradientStart, FallbackValue=#7B61FF, Converter={StaticResource HexToBrush}}" Offset="0"/>
                                        <GradientStop Color="{Binding ActiveStory.GradientEnd, FallbackValue=#00D4FF, Converter={StaticResource HexToBrush}}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#33FFFFFF" Height="3" CornerRadius="2"
                                            Margin="14,14,14,0" HorizontalAlignment="Stretch">
                                        <Border Background="White" Height="3" CornerRadius="2"
                                                HorizontalAlignment="Left" Width="160"/>
                                    </Border>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding ActiveStory.PlaceholderText}"
                                               Foreground="#22FFFFFF"
                                               FontFamily="{StaticResource UiFontSemibold}"
                                               FontSize="120"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Grid Grid.Row="1" Margin="14">
                                        <StackPanel VerticalAlignment="Top" Margin="0,16,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <c:AvatarControl Size="36"
                                                                 Initials="{Binding ActiveStory.Author.Initials, FallbackValue='?'}"
                                                                 ColorStart="{Binding ActiveStory.Author.AvatarColorStart, FallbackValue='#7B61FF'}"
                                                                 ColorEnd="{Binding ActiveStory.Author.AvatarColorEnd, FallbackValue='#00D4FF'}"/>
                                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ActiveStory.Author.FullName}"
                                                               Foreground="White"
                                                               FontFamily="{StaticResource UiFontSemibold}"/>
                                                    <TextBlock Text="{Binding ActiveStory.TimeAgo}"
                                                               Foreground="#CCFFFFFF"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ActiveStory.Caption}"
                                                       Foreground="White"
                                                       FontSize="14"
                                                       Margin="0,12,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Grid.Row="2" Margin="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#33FFFFFF" CornerRadius="22" Padding="16,10">
                                            <TextBlock Text="Ответьте на историю..."
                                                       Foreground="#CCFFFFFF"/>
                                        </Border>
                                        <Button Grid.Column="1"
                                                Width="44" Height="44"
                                                Margin="8,0,0,0"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                Command="{Binding LikeStoryCommand}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="#33FFFFFF" CornerRadius="22">
                                                        <Path Data="M 6 0 L 8 4 L 12 4 L 9 7 L 10 11 L 6 9 L 2 11 L 3 7 L 0 4 L 4 4 Z"
                                                              StrokeThickness="1.6" Stretch="Uniform"
                                                              Width="20" Height="20"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Stroke" Value="White"/>
                                                                    <Setter Property="Fill" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ActiveStory.IsLiked}" Value="True">
                                                                            <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                                                            <Setter Property="Stroke" Value="{DynamicResource DangerBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                            <Button Width="32" Height="32"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-44,0,0"
                                    Background="#44FFFFFF"
                                    Cursor="Hand"
                                    Command="{Binding CloseStoryCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                            <Path Data="M 0 0 L 10 10 M 10 0 L 0 10"
                                                  Stroke="White" StrokeThickness="1.6"
                                                  Stretch="Uniform"
                                                  Width="12" Height="12"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>