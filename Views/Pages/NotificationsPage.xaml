<UserControl x:Class="Engine.Views.Pages.NotificationsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Engine.Views.Controls"
             xmlns:m="clr-namespace:Engine.Models">
    <Grid Background="{DynamicResource PrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="32,28,32,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Уведомления" Style="{StaticResource TitleText}"/>
            <Button Grid.Column="1"
                    Content="Прочитать все"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding MarkAllNotificationsCommand}"/>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="32,8,32,32">
            <ItemsControl ItemsSource="{Binding Notifications}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type m:Notification}">
                        <Border Style="{StaticResource Card}" Margin="0,4" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <c:AvatarControl Size="40"
                                                 Initials="{Binding FromUser.Initials, FallbackValue='E'}"
                                                 ColorStart="{Binding FromUser.AvatarColorStart, FallbackValue='#7B61FF'}"
                                                 ColorEnd="{Binding FromUser.AvatarColorEnd, FallbackValue='#00D4FF'}"
                                                 Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}"
                                                   FontFamily="{StaticResource UiFontSemibold}"
                                                   FontSize="13"/>
                                        <Border Background="{DynamicResource HoverBrush}" CornerRadius="3"
                                                Padding="4,1" Margin="6,0,0,0">
                                            <TextBlock Text="{Binding KindText}" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Body}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding TimeAgo}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <Ellipse Width="8" Height="8" Margin="0,4,0,0"
                                             HorizontalAlignment="Right"
                                             Fill="{DynamicResource AccentBrush}"
                                             Visibility="{Binding IsRead, Converter={StaticResource InvBoolToVis2}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>