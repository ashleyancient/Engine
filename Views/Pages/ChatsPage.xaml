<UserControl x:Class="Engine.Views.Pages.ChatsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Engine.Views.Controls"
             xmlns:vm="clr-namespace:Engine.ViewModels"
             xmlns:m="clr-namespace:Engine.Models">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: chat list -->
        <Grid Grid.Column="0" Background="{DynamicResource SurfaceBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="14,16,14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Чаты" Style="{StaticResource HeaderText}" FontSize="18" VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Width="36" Height="36"
                        Background="{DynamicResource AccentGradientBrush}"
                        Foreground="White"
                        ToolTip="Новый чат">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                <Path Data="M 0 6 L 12 6 M 6 0 L 6 12"
                                      Stroke="White" StrokeThickness="1.8"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Width="14" Height="14" Stretch="Uniform"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <TextBox Grid.Row="1" Style="{StaticResource SearchBox}"
                     Margin="14,0,14,8"
                     Text="{Binding ChatVM.SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Поиск"/>

            <ScrollViewer Grid.Row="2"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="14,0,14,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Все" Margin="0,0,6,0"
                            Command="{Binding ChatVM.SetFilterCommand}"
                            CommandParameter="all">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                <Setter Property="Padding" Value="14,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ChatVM.IsFilterAll}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Непрочитанные" Margin="0,0,6,0"
                            Command="{Binding ChatVM.SetFilterCommand}"
                            CommandParameter="unread">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                <Setter Property="Padding" Value="14,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ChatVM.IsFilterUnread}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Группы" Margin="0,0,6,0"
                            Command="{Binding ChatVM.SetFilterCommand}"
                            CommandParameter="groups">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                <Setter Property="Padding" Value="14,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ChatVM.IsFilterGroups}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Каналы"
                            Command="{Binding ChatVM.SetFilterCommand}"
                            CommandParameter="channels">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                                <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                <Setter Property="Padding" Value="14,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ChatVM.IsFilterChannels}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <ListBox Grid.Row="3"
                     ItemsSource="{Binding ChatVM.FilteredChats}"
                     SelectedItem="{Binding ChatVM.SelectedChat, Mode=TwoWay}"
                     Padding="6,0,6,12">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <c:ChatListItem Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                            <c:ChatListItem.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Закрепить / Открепить"
                                              Command="{Binding PlacementTarget.Tag.ChatVM.TogglePinCommand,
                                                       RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="Заглушить"
                                              Command="{Binding PlacementTarget.Tag.ChatVM.ToggleMuteCommand,
                                                       RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding}"/>
                                    <MenuItem Header="Архивировать"
                                              Command="{Binding PlacementTarget.Tag.ChatVM.ArchiveCommand,
                                                       RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding}"/>
                                    <Separator/>
                                    <MenuItem Header="Удалить чат"
                                              Command="{Binding PlacementTarget.Tag.ChatVM.DeleteChatCommand,
                                                       RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding}"/>
                                </ContextMenu>
                            </c:ChatListItem.ContextMenu>
                        </c:ChatListItem>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}"/>

        <!-- RIGHT: chat detail -->
        <Grid Grid.Column="2" Background="{DynamicResource PrimaryBrush}">
            <ContentControl Content="{Binding ChatVM}">
                <ContentControl.ContentTemplate>
                    <DataTemplate DataType="{x:Type vm:ChatViewModel}">
                        <Grid>
                            <!-- Empty state -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding HasSelectedChat, Converter={StaticResource InvBoolToVis2}}">
                                <Border Width="120" Height="120"
                                        CornerRadius="60"
                                        Background="{DynamicResource CardBrush}">
                                    <TextBlock Text="E"
                                               FontFamily="{StaticResource UiFontSemibold}"
                                               FontSize="56"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                                <TextBlock Text="Выберите чат, чтобы начать общение"
                                           Style="{StaticResource HeaderText}"
                                           HorizontalAlignment="Center"
                                           Margin="0,18,0,4"/>
                                <TextBlock Text="Connect beyond limits"
                                           Style="{StaticResource SecondaryText}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Detail -->
                            <Grid Visibility="{Binding HasSelectedChat, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="1"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- HEADER -->
                                <Grid Grid.Row="0" Background="{DynamicResource SurfaceBrush}" Padding="0">
                                    <Grid Margin="20,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <c:AvatarControl Grid.Column="0"
                                                         Size="40"
                                                         Initials="{Binding SelectedChat.Initials}"
                                                         ColorStart="{Binding SelectedChat.AvatarColorStart}"
                                                         ColorEnd="{Binding SelectedChat.AvatarColorEnd}"
                                                         ShowOnline="{Binding SelectedChat.Counterpart.IsOnline, FallbackValue=False, TargetNullValue=False}"
                                                         Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SelectedChat.Title}"
                                                       FontFamily="{StaticResource UiFontSemibold}"
                                                       FontSize="15"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding SelectedChat.SubtitleText}"
                                                           Style="{StaticResource SecondaryText}"/>
                                                <TextBlock Text=" · печатает..."
                                                           Style="{StaticResource SecondaryText}"
                                                           Foreground="{DynamicResource AccentSecondaryBrush}"
                                                           Visibility="{Binding SelectedChat.IsTyping, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Style="{StaticResource IconButton}" ToolTip="Поиск">
                                                <Path Data="M 6 6 A 4 4 0 1 0 6 6.01 M 9 9 L 12 12"
                                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                                      StrokeThickness="1.6" Width="14" Height="14" Stretch="Uniform"/>
                                            </Button>
                                            <Button Style="{StaticResource IconButton}" ToolTip="Аудио-звонок">
                                                <Path Data="M 2 4 L 4 2 L 6 4 L 5 6 A 6 6 0 0 0 8 9 L 10 8 L 12 10 L 10 12 A 10 10 0 0 1 2 4 Z"
                                                      Fill="{DynamicResource TextSecondaryBrush}" Stretch="Uniform" Width="14" Height="14"/>
                                            </Button>
                                            <Button Style="{StaticResource IconButton}" ToolTip="Видео-звонок">
                                                <Path Data="M 0 2 L 10 2 L 10 10 L 0 10 Z M 10 4 L 14 2 L 14 10 L 10 8 Z"
                                                      Fill="{DynamicResource TextSecondaryBrush}" Stretch="Uniform" Width="14" Height="14"/>
                                            </Button>
                                            <Button Style="{StaticResource IconButton}" ToolTip="Ещё">
                                                <TextBlock Text="..." FontSize="16" FontFamily="{StaticResource UiFontSemibold}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <Rectangle Grid.Row="1" Fill="{DynamicResource BorderBrush}"/>

                                <!-- MESSAGES -->
                                <ScrollViewer Grid.Row="2" x:Name="MessagesScroll"
                                              VerticalScrollBarVisibility="Auto"
                                              Padding="20,16">
                                    <ItemsControl ItemsSource="{Binding SelectedChatMessages}"
                                                  HorizontalContentAlignment="Stretch">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type m:Message}">
                                                <Grid>
                                                    <c:MessageBubble>
                                                        <c:MessageBubble.Style>
                                                            <Style TargetType="{x:Type c:MessageBubble}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Type}" Value="System">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </c:MessageBubble.Style>
                                                    </c:MessageBubble>
                                                    <TextBlock Text="{Binding Text}"
                                                               HorizontalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,6"
                                                               Visibility="{Binding Type, Converter={StaticResource StrEqVis}, ConverterParameter=System}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- INPUT -->
                                <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" Padding="20,12">
                                    <StackPanel>
                                        <Border Background="{DynamicResource CardBrush}"
                                                CornerRadius="10"
                                                Padding="10,8"
                                                Margin="0,0,0,8"
                                                Visibility="{Binding HasReply, Converter={StaticResource BoolToVis}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="2"/>
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="Ответ на сообщение"
                                                               Style="{StaticResource SecondaryText}"
                                                               Foreground="{DynamicResource AccentSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding ReplyTo.Text}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </StackPanel>
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource IconButton}"
                                                        Width="28" Height="28"
                                                        Command="{Binding CancelReplyCommand}">
                                                    <Path Data="M 0 0 L 8 8 M 8 0 L 0 8"
                                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                                          StrokeThickness="1.5" Stretch="Uniform" Width="10" Height="10"/>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <Border Background="{DynamicResource CardBrush}" CornerRadius="22" Padding="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Style="{StaticResource IconButton}"
                                                        ToolTip="Реакции">
                                                    <Path Data="M 7 0 A 7 7 0 1 1 6.99 0 M 4 5 L 4 5 M 10 5 L 10 5 M 4 9 A 3 3 0 0 0 10 9"
                                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                                          StrokeThickness="1.4"
                                                          Stretch="Uniform" Width="18" Height="18"/>
                                                </Button>
                                                <TextBox Grid.Column="1"
                                                         Style="{StaticResource MessageInputBox}"
                                                         Text="{Binding DraftText, UpdateSourceTrigger=PropertyChanged}"
                                                         x:Name="MessageInput"
                                                         KeyDown="OnInputKeyDown"
                                                         Margin="6,0"
                                                         VerticalAlignment="Center"/>
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource IconButton}"
                                                        ToolTip="Прикрепить">
                                                    <Path Data="M 8 0 L 8 12 M 4 4 L 8 0 L 12 4"
                                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                                          StrokeThickness="1.6" Stretch="Uniform" Width="14" Height="14"/>
                                                </Button>
                                                <Button Grid.Column="3"
                                                        Width="40" Height="40"
                                                        Margin="6,0,0,0"
                                                        Background="{DynamicResource AccentGradientBrush}"
                                                        Foreground="White"
                                                        Cursor="Hand"
                                                        Command="{Binding SendMessageCommand}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                                                <Path x:Name="Glyph"
                                                                      Data="M 0 0 L 12 6 L 0 12 L 3 6 Z"
                                                                      Fill="White" Stretch="Uniform"
                                                                      Width="14" Height="14"
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding HasDraft}" Value="False">
                                                                    <Setter TargetName="Glyph" Property="Data"
                                                                            Value="M 6 0 A 3 3 0 0 1 9 3 L 9 7 A 3 3 0 0 1 3 7 L 3 3 A 3 3 0 0 1 6 0 Z M 1 8 A 5 5 0 0 0 11 8 M 6 13 L 6 16 M 3 16 L 9 16"/>
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>