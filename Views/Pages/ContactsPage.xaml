<UserControl x:Class="Engine.Views.Pages.ContactsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Engine.Views.Controls"
             xmlns:m="clr-namespace:Engine.Models">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{DynamicResource SurfaceBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Margin="14,16,14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Контакты" Style="{StaticResource HeaderText}" FontSize="18" VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Width="36" Height="36"
                        Background="{DynamicResource AccentGradientBrush}"
                        Foreground="White"
                        Command="{Binding ContactsVM.AddContactCommand}"
                        ToolTip="Добавить контакт">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                <Path Data="M 0 6 L 12 6 M 6 0 L 6 12"
                                      Stroke="White" StrokeThickness="1.8"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Width="14" Height="14" Stretch="Uniform"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            <TextBox Grid.Row="1" Style="{StaticResource SearchBox}"
                     Margin="14,0,14,8"
                     Text="{Binding ContactsVM.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            <ScrollViewer Grid.Row="2" Padding="6,0,6,12">
                <StackPanel>
                    <TextBlock Text="В сети" Style="{StaticResource SecondaryText}" Margin="14,12,0,8"
                               Visibility="{Binding ContactsVM.OnlineContacts.Count, Converter={StaticResource CountToVis}}"/>
                    <ItemsControl ItemsSource="{Binding ContactsVM.OnlineContacts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:User}">
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="8,6"
                                        Margin="0,2"
                                        Command="{Binding DataContext.ContactsVM.OpenProfileCommand,
                                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <c:AvatarControl Size="40"
                                                         Initials="{Binding Initials}"
                                                         ColorStart="{Binding AvatarColorStart}"
                                                         ColorEnd="{Binding AvatarColorEnd}"
                                                         ShowOnline="{Binding IsOnline}"
                                                         Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}"
                                                       FontFamily="{StaticResource UiFontSemibold}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="в сети"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource OnlineBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="Все контакты" Style="{StaticResource SecondaryText}" Margin="14,12,0,8"/>
                    <ItemsControl ItemsSource="{Binding ContactsVM.SortedContacts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:User}">
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="8,6"
                                        Margin="0,2"
                                        Command="{Binding DataContext.ContactsVM.OpenProfileCommand,
                                                 RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <c:AvatarControl Size="40"
                                                         Initials="{Binding Initials}"
                                                         ColorStart="{Binding AvatarColorStart}"
                                                         ColorEnd="{Binding AvatarColorEnd}"
                                                         ShowOnline="{Binding IsOnline}"
                                                         Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}"
                                                       FontFamily="{StaticResource UiFontSemibold}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                                <Run Text="@"/>
                                                <Run Text="{Binding Username, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}"/>

        <Grid Grid.Column="2" Background="{DynamicResource PrimaryBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding ContactsVM.IsProfileVisible, Converter={StaticResource InvBoolToVis2}}">
                <TextBlock Text="Выберите контакт"
                           Style="{StaticResource HeaderText}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="чтобы увидеть профиль и начать общение"
                           Style="{StaticResource SecondaryText}"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <Border MaxWidth="480" Margin="40"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="14" Padding="32"
                    Visibility="{Binding ContactsVM.IsProfileVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <c:AvatarControl Size="96"
                                     Initials="{Binding ContactsVM.SelectedContact.Initials, FallbackValue='?'}"
                                     ColorStart="{Binding ContactsVM.SelectedContact.AvatarColorStart, FallbackValue='#7B61FF'}"
                                     ColorEnd="{Binding ContactsVM.SelectedContact.AvatarColorEnd, FallbackValue='#00D4FF'}"
                                     ShowOnline="{Binding ContactsVM.SelectedContact.IsOnline, FallbackValue=False}"
                                     HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ContactsVM.SelectedContact.FullName}"
                               Style="{StaticResource TitleText}"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,2"/>
                    <TextBlock HorizontalAlignment="Center" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="@"/>
                        <Run Text="{Binding ContactsVM.SelectedContact.Username, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding ContactsVM.SelectedContact.Bio}"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding ContactsVM.SelectedContact.PhoneNumber}"
                               TextAlignment="Center"
                               FontFamily="{StaticResource MonoFont}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Написать"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding OpenChatFromContactCommand}"
                                CommandParameter="{Binding ContactsVM.SelectedContact}"/>
                        <Button Grid.Column="2" Content="Закрыть"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding ContactsVM.CloseProfileCommand}"/>
                    </Grid>
                    <Button Content="Заблокировать"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ContactsVM.BlockCommand}"
                            Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>