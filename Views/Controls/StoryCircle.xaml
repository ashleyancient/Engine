<UserControl x:Class="Engine.Views.Controls.StoryCircle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Engine.Views.Controls">
    <StackPanel Width="84" Margin="6,0">
        <Grid Width="68" Height="68" HorizontalAlignment="Center">
            <Ellipse Width="68" Height="68">
                <Ellipse.Stroke>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7B61FF" Offset="0"/>
                        <GradientStop Color="#00D4FF" Offset="1"/>
                    </LinearGradientBrush>
                </Ellipse.Stroke>
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="StrokeThickness" Value="2.5"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsViewed}" Value="True">
                                <Setter Property="Stroke" Value="{DynamicResource BorderBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <c:AvatarControl Size="58"
                             Initials="{Binding Author.Initials, FallbackValue='?'}"
                             ColorStart="{Binding Author.AvatarColorStart, FallbackValue='#7B61FF'}"
                             ColorEnd="{Binding Author.AvatarColorEnd, FallbackValue='#00D4FF'}"/>
        </Grid>
        <TextBlock Text="{Binding Author.FirstName, FallbackValue='Автор'}"
                   FontSize="11"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,6,0,0"
                   TextTrimming="CharacterEllipsis"/>
    </StackPanel>
</UserControl>