<UserControl x:Class="Engine.Views.Controls.AvatarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Grid Width="{Binding Size, ElementName=Root}"
          Height="{Binding Size, ElementName=Root}">
        <Ellipse>
            <Ellipse.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{Binding ColorStartValue, ElementName=Root}" Offset="0"/>
                    <GradientStop Color="{Binding ColorEndValue, ElementName=Root}" Offset="1"/>
                </LinearGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <TextBlock Text="{Binding Initials, ElementName=Root}"
                   Foreground="White"
                   FontFamily="{StaticResource UiFontSemibold}"
                   FontSize="{Binding InitialsFontSize, ElementName=Root}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        <Ellipse x:Name="OnlineDot"
                 Width="12" Height="12"
                 Fill="{DynamicResource OnlineBrush}"
                 Stroke="{DynamicResource SurfaceBrush}"
                 StrokeThickness="2"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Visibility="{Binding ShowOnline, ElementName=Root, Converter={StaticResource BoolToVis}}"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="DotScale" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetName="DotScale"
                                             Storyboard.TargetProperty="ScaleX"
                                             From="1" To="1.4" Duration="0:0:1"/>
                            <DoubleAnimation Storyboard.TargetName="DotScale"
                                             Storyboard.TargetProperty="ScaleY"
                                             From="1" To="1.4" Duration="0:0:1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>
    </Grid>
</UserControl>