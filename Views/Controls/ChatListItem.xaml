<UserControl x:Class="Engine.Views.Controls.ChatListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:Engine.Views.Controls"
             SnapsToDevicePixels="True">
    <Grid Margin="8,4" Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <c:AvatarControl Grid.Column="0" Grid.RowSpan="2"
                         Size="46"
                         Initials="{Binding Initials}"
                         ColorStart="{Binding AvatarColorStart}"
                         ColorEnd="{Binding AvatarColorEnd}"
                         ShowOnline="{Binding Counterpart.IsOnline, FallbackValue=False, TargetNullValue=False}"
                         Margin="0,2,12,2"
                         VerticalAlignment="Center"/>

        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="{Binding Title}"
                       FontFamily="{StaticResource UiFontSemibold}"
                       FontSize="14"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"/>
            <Border Background="{DynamicResource HoverBrush}"
                    CornerRadius="3"
                    Padding="4,1"
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="закреп" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Border>
            <Border Background="{DynamicResource HoverBrush}"
                    CornerRadius="3"
                    Padding="4,1"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsMuted, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="без звука" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Border>
        </StackPanel>

        <TextBlock Grid.Column="2" Grid.Row="0"
                   Text="{Binding LastMessageTime}"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center"/>

        <TextBlock Grid.Column="1" Grid.Row="1"
                   Text="{Binding LastMessagePreview}"
                   FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,2,0,0"/>

        <Border Grid.Column="2" Grid.Row="1"
                Background="{DynamicResource AccentBrush}"
                CornerRadius="10"
                MinWidth="20" Height="20"
                Padding="6,0"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Visibility="{Binding HasUnread, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding UnreadCount}"
                       Foreground="White"
                       FontSize="11"
                       FontFamily="{StaticResource UiFontSemibold}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>